# Environment Variables — Gridiron Cards
# Copy to .env and fill in values BEFORE deploying

# ==============================
# SUPABASE (Required)
# Get from: supabase.com → Project Settings → API
# ==============================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==============================
# APP CONFIG
# ==============================
NODE_ENV=production
PORT=3000

# Generate with: openssl rand -base64 32
JWT_SECRET=generate-a-random-secret-here

# ==============================
# CORS
# ==============================
CORS_ORIGIN=http://srv1561102.hstgr.cloud:4000

# ==============================
# TANK01 NFL API (Optional at start)
# Can also be set via admin panel (/admin/config)
# Get from: https://rapidapi.com/tank01/api/tank01-nfl-live-in-game-real-time-statistics-nfl
# ==============================
TANK01_API_KEY=

# ==============================
# LOGGING
# ==============================
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==============================
# FRONTEND (Vite build-time vars)
# These are embedded into the frontend build
# ==============================
VITE_API_URL=http://srv1561102.hstgr.cloud:4000/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
